<%= form_with(model: attr) do |form| %>
  <% if attr.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(attr.errors.count, "error") %> prohibited this attr from being saved:</h2>

      <ul>
        <% attr.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :attr_title, style: "display: block" %>
    <%= form.text_field :attr_title %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
