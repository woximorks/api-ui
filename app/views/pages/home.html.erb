<div id="endpoints">
  <% @endpoints.each do |endpoint| %>
    <b><%= endpoint.endpoint_title %></b>
  <% end %>
</div>
<hr>
<div id="attrs">
  <% @attrs.each do |attr| %>
    <%= attr.attr_title %>,
  <% end %>
</div>
<hr>
<div id="endpoint_associated_attrs">
  <% @endpoint_associated_attrs.each do |endpoint_associated_attr| %>
    <%= [endpoint_associated_attr.endpoint.endpoint_title, endpoint_associated_attr.attr.attr_title] %>,
  <% end %>
</div>
